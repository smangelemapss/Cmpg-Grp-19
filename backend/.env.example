# Oracle Database
ORA_USER=system
ORA_PASSWORD=your_oracle_password
ORA_HOST=localhost
ORA_PORT=1521
ORA_SID=XE

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Flask
FLASK_ENV=development
FLASK_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000