# Oracle Database
ORA_USER=system
ORA_PASSWORD=your_oracle_password
ORA_HOST=localhost
ORA_PORT=1521
ORA_SID=XE
# Optional: use service name instead of SID (e.g. XEPDB1 for pluggable DB)
# ORA_SERVICE_NAME=XEPDB1

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Flask
FLASK_ENV=development
FLASK_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Optional: set DEBUG_LOG=true to write agent debug traces to debug-b3fe85.log
DEBUG_LOG=false

# Oracle connection pool (performance NFR)
ORA_POOL_MIN=2
ORA_POOL_MAX=10
ORA_POOL_INCREMENT=1

# Auth rate limiting (security + availability NFR)
AUTH_RATE_LIMIT_WINDOW_SEC=60
AUTH_RATE_LIMIT_MAX=15
# DISABLE_RATE_LIMIT=true

# NFR benchmark script (scripts/verify_nfr_performance.py)
# NFR_DEMO_USER=karabo.mabena
# NFR_DEMO_PASS=Clinic@123